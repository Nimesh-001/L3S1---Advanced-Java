package com.ictec.client;

import com.ictec.calc.Calculator;
import com.ictec.calc.Mycalculator;

import java.rmi.NotBoundException;
import java.rmi.RemoteException;
import java.rmi.registry.LocateRegistry;
import java.rmi.registry.Registry;

public class Myclient {
    public static void main(String[] args) {
        try {
            Registry registry = LocateRegistry.getRegistry("localhost", 54321);
            Calculator cal = (Calculator) registry.lookup("Calculator");

            double add = cal.addtwonumber(10,20);
            System.out.println("result = "+add);

            double sub = cal.subtwonumber(20, 10);
            System.out.println("Subtraction Result = " + sub);

            double mul = cal.multtwonumber(10, 5);
            System.out.println("Multiplication Result = " + mul);

            double div = cal.divtwonumber(20, 5);
            System.out.println("Division Result = " + div);

        } catch (RemoteException e) {
            throw new RuntimeException(e);
        } catch (NotBoundException e) {
            throw new RuntimeException(e);
        }

    }
}


