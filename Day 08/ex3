package com.ictec.calc;

import java.rmi.Remote;
import java.rmi.RemoteException;

public interface Calculator extends Remote {
    public double addtwonumber(double num1, double num2) throws RemoteException;
    public double subtwonumber(double num1, double num2) throws RemoteException;
    public double multtwonumber(double num1, double num2) throws RemoteException;
    public double divtwonumber(double num1, double num2) throws RemoteException;

}

