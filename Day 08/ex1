import java.io.DataInputStream;
import java.io.DataOutputStream;
import java.io.IOException;
import java.net.Socket;
import java.sql.Connection;
import java.sql.PreparedStatement;
import java.sql.SQLException;

public class ClientHandler implements Runnable {

    private Socket socket;
    private Connection con;

    public ClientHandler(Socket socket, Connection con) {
        this.socket = socket;
        this.con = con;
    }

    @Override
    public void run() {
        try {
            DataInputStream in = new DataInputStream(socket.getInputStream());
            DataOutputStream out = new DataOutputStream(socket.getOutputStream());

            String msg = "";
            int count = 0;

            while (count < 5) {
                msg = in.readUTF();
                System.out.println("client : " + msg);

                out.writeUTF(msg);
                out.flush();


                try {
                    String sql = "INSERT INTO messages(client_ip, message) VALUES(?, ?)";
                    PreparedStatement pst = con.prepareStatement(sql);
                    pst.setString(1, socket.getRemoteSocketAddress().toString());
                    pst.setString(2, msg);
                    pst.executeUpdate();
                    pst.close();
                } catch (SQLException e) {
                    System.out.println("Failed to insert message into DB.");
                    e.printStackTrace();
                }

                count++;
            }


            in.close();
            out.close();
            socket.close();
            System.out.println("Client disconnected.");

        } catch (IOException e) {
            throw new RuntimeException(e);
        }
    }
}

