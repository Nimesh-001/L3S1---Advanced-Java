import java.util.concurrent.ScheduledThreadPoolExecutor;
import java.util.concurrent.TimeUnit;

public class coffedemo {
    public static void main(String[] args) {
        ScheduledThreadPoolExecutor executor = new ScheduledThreadPoolExecutor(1);

        Mycoffeevent cofee = new Mycoffeevent("ading coffe..");
        Mycoffeevent sugar = new Mycoffeevent("adding sugar..");
        Mycoffeevent water = new Mycoffeevent("adding water...");
        Mycoffeevent serve = new Mycoffeevent("serving the cofee...");


        for (int i=1; i<=2; i++) {
            executor.schedule(new Mytimer(i), i, TimeUnit.SECONDS);

        }



        executor.schedule(cofee,4, TimeUnit.SECONDS);
        executor.schedule(sugar,7, TimeUnit.SECONDS);
        executor.schedule(water,11, TimeUnit.SECONDS);
        executor.schedule(serve,20, TimeUnit.SECONDS);

        executor. shutdown();
    }
}

