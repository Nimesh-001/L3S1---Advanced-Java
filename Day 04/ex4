public class Kamal implements Runnable {

    private Paper paper;
    private Pen pen;

    public Kamal(Paper paper, Pen pen) {
        this.paper = paper;
        this.pen = pen;
    }

    @Override
    public void run() {
        synchronized (pen) { // lock the object this is the solution for the deadlock, that mean use object level lock.
            paper.writewithpen(pen);

        }
    }


}

